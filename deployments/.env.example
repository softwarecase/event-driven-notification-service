# 1. Copy this file: cp .env.example .env
# 2. Get your webhook URL at https://webhook.site
# 3. Replace YOUR-UUID-HERE below
# For load testing use mock provider: WEBHOOK_URL=http://mockprovider

# Webhook provider
WEBHOOK_URL=https://webhook.site/YOUR-UUID-HERE

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=notifications

# Redis (empty = no password)
REDIS_PASSWORD=

